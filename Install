#!/bin/bash

set -euo pipefail

REQ_FILE="requirements.txt"

MAX_JOBS="${MAX_JOBS:-1}"

TORCH_VERSION="2.6.0"
TORCHVISION_VERSION="0.21.0"
TORCHAUDIO_VERSION="2.6.0"
TRITON_VERSION="3.2.0"
VLLM_VERSION="0.8.3"
TRL_VERSION="0.26.2"

INSTALL_FLASH_ATTN="${INSTALL_FLASH_ATTN:-1}"
INSTALL_XFORMERS="${INSTALL_XFORMERS:-1}"

FLASH_ATTN_WHEEL_URL="https://github.com/Dao-AILab/flash-attention/releases/download/v2.7.4.post1/flash_attn-2.7.4.post1+cu12torch2.6cxx11abiFALSE-cp310-cp310-linux_x86_64.whl"
XFORMERS_VERSION="0.0.29.post2"

echo "=== Install uv ==="
python -m pip install -U uv

if [ ! -f "$REQ_FILE" ]; then
  echo "ERROR: Cannot find $REQ_FILE in current directory:"
  pwd
  echo ""
  echo "Files matching requirements:"
  ls -lh | grep requirements || true
  exit 1
fi

echo ""
echo "Using base requirements file: $REQ_FILE"
echo "Torch source: PyPI CUDA 12 wheels"
echo "INSTALL_FLASH_ATTN=$INSTALL_FLASH_ATTN"
echo "INSTALL_XFORMERS=$INSTALL_XFORMERS"
echo "MAX_JOBS=$MAX_JOBS"
echo ""

echo "=== Safety check: requirements.txt should only contain base packages ==="
BAD_LINES="$(grep -En '^(torch|torchvision|torchaudio|triton|vllm|trl|xformers|flash_attn|flash-attn|lightgbm|together)([=<>!~ ]|$)' "$REQ_FILE" || true)"

if [ -n "$BAD_LINES" ]; then
  echo "ERROR: requirements.txt still contains packages that should NOT be installed in the base round:"
  echo "$BAD_LINES"
  echo ""
  echo "Please remove/comment these from requirements.txt."
  echo "This script installs torch/triton/vllm/trl/flash-attn/xformers manually later."
  exit 1
fi

echo "OK: no forbidden CUDA/vLLM packages found in requirements.txt."
echo ""

echo "=== Upgrade installer tools ==="
uv pip install --upgrade pip setuptools wheel ninja packaging cmake

echo ""
echo "=== Install base packages normally from PyPI ==="
uv pip install \
  --index-url https://pypi.org/simple \
  --pre \
  -r "$REQ_FILE"

echo ""
echo "=== Remove old mismatched CUDA / vLLM / attention stack if present ==="
uv pip uninstall -y torch torchvision torchaudio triton vllm trl flash-attn flash_attn xformers || true

echo ""
echo "=== Install PyTorch CUDA 12 stack from PyPI WITH deps ==="
echo "Important: no --no-deps here, because torch must pull NVIDIA CUDA 12 runtime libs."
uv pip install \
  --index-url https://pypi.org/simple \
  "torch==$TORCH_VERSION" \
  "torchvision==$TORCHVISION_VERSION" \
  "torchaudio==$TORCHAUDIO_VERSION"

echo ""
echo "=== Add NVIDIA pip CUDA libs to LD_LIBRARY_PATH ==="
export LD_LIBRARY_PATH="$(python - <<'PY'
import site, glob, os

paths = []
for sp in site.getsitepackages():
    paths.extend(glob.glob(os.path.join(sp, "nvidia", "*", "lib")))

seen = set()
out = []
for p in paths:
    if p not in seen:
        seen.add(p)
        out.append(p)

print(":".join(out))
PY
):${LD_LIBRARY_PATH:-}"

echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH"

echo ""
echo "=== Check torch ==="
python - <<'PY'
import torch, sys
print("python:", sys.version)
print("torch:", torch.__version__)
print("torch cuda:", torch.version.cuda)
print("cuda available:", torch.cuda.is_available())
print("cxx11 abi:", torch._C._GLIBCXX_USE_CXX11_ABI)

if torch.cuda.is_available():
    print("device:", torch.cuda.get_device_name(0))
    print("capability:", torch.cuda.get_device_capability(0))
PY

echo ""
echo "=== Install vLLM / TRL stack manually, no deps / no build isolation ==="
uv pip install \
  --no-deps \
  --no-build-isolation \
  --index-url https://pypi.org/simple \
  "triton==$TRITON_VERSION" \
  "vllm==$VLLM_VERSION" \
  "trl==$TRL_VERSION"

echo ""
echo "=== Refresh NVIDIA pip CUDA libs in LD_LIBRARY_PATH ==="
export LD_LIBRARY_PATH="$(python - <<'PY'
import site, glob, os

paths = []
for sp in site.getsitepackages():
    paths.extend(glob.glob(os.path.join(sp, "nvidia", "*", "lib")))

seen = set()
out = []
for p in paths:
    if p not in seen:
        seen.add(p)
        out.append(p)

print(":".join(out))
PY
):${LD_LIBRARY_PATH:-}"

echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH"

echo ""
if [ "$INSTALL_FLASH_ATTN" = "1" ]; then
  echo "=== Install flash-attn prebuilt wheel ==="
  uv pip install \
    --no-deps \
    "$FLASH_ATTN_WHEEL_URL"
else
  echo "=== Skipping flash-attn ==="
fi

echo ""
if [ "$INSTALL_XFORMERS" = "1" ]; then
  echo "=== Install xformers ==="

  echo ""
  echo "=== Step 1: Try xformers binary wheel first ==="
  set +e
  uv pip install \
    --only-binary=:all: \
    --no-deps \
    "xformers==$XFORMERS_VERSION"
  XFORMERS_BINARY_STATUS=$?
  set -e

  if [ "$XFORMERS_BINARY_STATUS" -ne 0 ]; then
    echo ""
    echo "xformers binary wheel failed. Building xformers from source."

    echo ""
    echo "=== Step 2: Install conda compiler + complete CUDA toolkit/dev headers/libs ==="
    conda install -c conda-forge gcc_linux-64=12 gxx_linux-64=12 cmake ninja git -y

    # Complete CUDA toolkit + CCCL/libcu++ headers.
    # Fixes: fatal error: nv/target: No such file or directory
    conda install -c conda-forge \
      "cuda-toolkit=12.4" \
      "cuda-cccl=12.4" \
      "cuda-cudart-dev=12.4" \
      "cuda-runtime=12.4" \
      -y || conda install -c conda-forge \
      "cuda-toolkit=12.4" \
      "cuda-cudart-dev=12.4" \
      -y

    echo ""
    echo "=== Step 3: Configure build environment for xformers ==="
    export CC="$CONDA_PREFIX/bin/x86_64-conda-linux-gnu-gcc"
    export CXX="$CONDA_PREFIX/bin/x86_64-conda-linux-gnu-g++"

    export CUDA_HOME="$CONDA_PREFIX"
    export CUDA_PATH="$CONDA_PREFIX"
    export PATH="$CUDA_HOME/bin:$PATH"

    # CUDA / CCCL / libcu++ headers.
    export CPATH="$CONDA_PREFIX/include:$CONDA_PREFIX/targets/x86_64-linux/include:${CPATH:-}"
    export C_INCLUDE_PATH="$CONDA_PREFIX/include:$CONDA_PREFIX/targets/x86_64-linux/include:${C_INCLUDE_PATH:-}"
    export CPLUS_INCLUDE_PATH="$CONDA_PREFIX/include:$CONDA_PREFIX/targets/x86_64-linux/include:${CPLUS_INCLUDE_PATH:-}"

    # Runtime + link-time library paths.
    export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:$CONDA_PREFIX/lib64:$CONDA_PREFIX/targets/x86_64-linux/lib:${LD_LIBRARY_PATH:-}"
    export LIBRARY_PATH="$CONDA_PREFIX/lib:$CONDA_PREFIX/lib64:$CONDA_PREFIX/targets/x86_64-linux/lib:${LIBRARY_PATH:-}"
    export LDFLAGS="-L$CONDA_PREFIX/lib -L$CONDA_PREFIX/lib64 -L$CONDA_PREFIX/targets/x86_64-linux/lib ${LDFLAGS:-}"

    export MAX_JOBS="$MAX_JOBS"
    export NVCC_THREADS=1
    export XFORMERS_BUILD_TYPE=Release
    export XFORMERS_DISABLE_FLASH_ATTN=1
    export NVCC_FLAGS="${NVCC_FLAGS:-} -allow-unsupported-compiler"

    export TORCH_CUDA_ARCH_LIST="$(python - <<'PY'
import torch

if torch.cuda.is_available():
    major, minor = torch.cuda.get_device_capability(0)
    print(f"{major}.{minor}")
else:
    # Fallback if building on a node without visible GPU.
    # V100=7.0, A100=8.0, A10/RTX30=8.6.
    print("7.0")
PY
)"

    echo "CC=$CC"
    echo "CXX=$CXX"
    echo "CUDA_HOME=$CUDA_HOME"
    echo "CUDA_PATH=$CUDA_PATH"
    echo "PATH=$PATH"
    echo "CPATH=$CPATH"
    echo "CPLUS_INCLUDE_PATH=$CPLUS_INCLUDE_PATH"
    echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH"
    echo "LIBRARY_PATH=$LIBRARY_PATH"
    echo "LDFLAGS=$LDFLAGS"
    echo "MAX_JOBS=$MAX_JOBS"
    echo "NVCC_THREADS=$NVCC_THREADS"
    echo "TORCH_CUDA_ARCH_LIST=$TORCH_CUDA_ARCH_LIST"
    echo "XFORMERS_DISABLE_FLASH_ATTN=$XFORMERS_DISABLE_FLASH_ATTN"
    echo "NVCC_FLAGS=$NVCC_FLAGS"

    echo ""
    echo "=== Compiler / CUDA versions ==="
    which gcc || true
    which g++ || true
    which nvcc || true
    gcc --version || true
    g++ --version || true
    nvcc --version || true

    echo ""
    echo "=== Check CUDA headers ==="
    find "$CONDA_PREFIX" -path "*/nv/target" -o -path "*/nv/target.h" || true
    find "$CONDA_PREFIX" -name cuda_fp16.h | head || true

    python - <<'PY'
import os
prefix = os.environ["CONDA_PREFIX"]
candidates = [
    f"{prefix}/include/nv/target",
    f"{prefix}/include/nv/target.h",
    f"{prefix}/targets/x86_64-linux/include/nv/target",
    f"{prefix}/targets/x86_64-linux/include/nv/target.h",
]
print("Checking nv/target candidates:")
for p in candidates:
    print(p, "exists=", os.path.exists(p))
PY

    echo ""
    echo "=== Fix CUDA runtime linker path for xformers ==="

    CUDA_LIB_CANDIDATES=(
      "$CONDA_PREFIX/lib"
      "$CONDA_PREFIX/lib64"
      "$CONDA_PREFIX/targets/x86_64-linux/lib"
    )

    PY_CUDA_LIBS="$(python - <<'PY'
import site, glob, os
paths = []
for sp in site.getsitepackages():
    paths.extend(glob.glob(os.path.join(sp, "nvidia", "*", "lib")))
print(" ".join(paths))
PY
)"

    for p in $PY_CUDA_LIBS; do
      CUDA_LIB_CANDIDATES+=("$p")
    done

    echo "Searching for libcudart..."
    for d in "${CUDA_LIB_CANDIDATES[@]}"; do
      if [ -d "$d" ]; then
        echo "  $d"
        ls "$d"/libcudart.so* 2>/dev/null || true
      fi
    done

    CUDART_REAL="$(find \
      "$CONDA_PREFIX/lib" \
      "$CONDA_PREFIX/lib64" \
      "$CONDA_PREFIX/targets/x86_64-linux/lib" \
      $PY_CUDA_LIBS \
      -name 'libcudart.so*' 2>/dev/null | head -n 1 || true)"

    if [ -z "$CUDART_REAL" ]; then
      echo "ERROR: Cannot find any libcudart.so*."
      echo "Installing cuda-cudart-dev and cuda-runtime again..."
      conda install -c conda-forge "cuda-cudart-dev=12.4" "cuda-runtime=12.4" -y

      CUDART_REAL="$(find \
        "$CONDA_PREFIX/lib" \
        "$CONDA_PREFIX/lib64" \
        "$CONDA_PREFIX/targets/x86_64-linux/lib" \
        -name 'libcudart.so*' 2>/dev/null | head -n 1 || true)"
    fi

    if [ -z "$CUDART_REAL" ]; then
      echo "ERROR: Still cannot find libcudart.so* after installing CUDA runtime."
      exit 1
    fi

    echo "Using CUDA runtime: $CUDART_REAL"

    mkdir -p "$CONDA_PREFIX/lib"

    # Make sure -lcudart can resolve.
    if [ ! -e "$CONDA_PREFIX/lib/libcudart.so" ]; then
      ln -sf "$CUDART_REAL" "$CONDA_PREFIX/lib/libcudart.so"
    fi

    export LIBRARY_PATH="$CONDA_PREFIX/lib:$CONDA_PREFIX/lib64:$CONDA_PREFIX/targets/x86_64-linux/lib:${LIBRARY_PATH:-}"
    export LDFLAGS="-L$CONDA_PREFIX/lib -L$CONDA_PREFIX/lib64 -L$CONDA_PREFIX/targets/x86_64-linux/lib ${LDFLAGS:-}"
    export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:$CONDA_PREFIX/lib64:$CONDA_PREFIX/targets/x86_64-linux/lib:${LD_LIBRARY_PATH:-}"

    echo "libcudart symlink:"
    ls -lh "$CONDA_PREFIX/lib/libcudart.so" || true
    echo "LIBRARY_PATH=$LIBRARY_PATH"
    echo "LDFLAGS=$LDFLAGS"
    echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH"

    echo ""
    echo "=== Torch before xformers build ==="
    python - <<'PY'
import torch
print("torch:", torch.__version__)
print("torch cuda:", torch.version.cuda)
print("cuda available:", torch.cuda.is_available())
print("cxx11 abi:", torch._C._GLIBCXX_USE_CXX11_ABI)
if torch.cuda.is_available():
    print("device:", torch.cuda.get_device_name(0))
    print("capability:", torch.cuda.get_device_capability(0))
PY

    echo ""
    echo "=== Step 4: Build xformers from source ==="
    echo "Build log will be saved to xformers_build.log"

    uv pip uninstall -y xformers || true

    set +e
    MAX_JOBS="$MAX_JOBS" NVCC_THREADS=1 python -m pip install \
      --no-deps \
      --no-build-isolation \
      --no-cache-dir \
      -v \
      "xformers==$XFORMERS_VERSION" 2>&1 | tee xformers_build.log

    XFORMERS_BUILD_STATUS=${PIPESTATUS[0]}
    set -e

    if [ "$XFORMERS_BUILD_STATUS" -ne 0 ]; then
      echo ""
      echo "ERROR: xformers source build failed."
      echo "Showing last 300 lines of xformers_build.log:"
      echo ""
      tail -n 300 xformers_build.log
      exit "$XFORMERS_BUILD_STATUS"
    fi
  fi
else
  echo "=== Skipping xformers ==="
fi

echo ""
echo "=== Final import check ==="
python - <<'PY'
import importlib

mods = [
    "torch",
    "transformers",
    "pandas",
    "numpy",
    "datasets",
    "peft",
    "accelerate",
    "trl",
    "vllm",
    "psutil",
    "dateutil",
    "sentencepiece",
    "chromadb",
    "openai",
    "autogen",
    "flash_attn",
    "xformers",
]

for name in mods:
    try:
        mod = importlib.import_module(name)
        version = getattr(mod, "__version__", "import ok")
        if name == "torch":
            print(f"{name}: {version}, cuda={mod.version.cuda}, cuda_available={mod.cuda.is_available()}")
        else:
            print(f"{name}: {version}")
    except Exception as e:
        print(f"{name} import failed: {repr(e)}")

print("")
print("=== xformers.ops check ===")
try:
    import xformers.ops
    print("xformers.ops: OK")
except Exception as e:
    print("xformers.ops failed:", repr(e))
PY

echo ""
echo "=== Basic vLLM CLI check ==="
python - <<'PY'
try:
    import vllm
    print("vllm import OK:", getattr(vllm, "__version__", "unknown"))
except Exception as e:
    print("vllm import failed:", repr(e))
    raise SystemExit(1)
PY

echo ""
echo "Install finished."

echo ""
echo "NOTE:"
echo "If you open a new shell later, you may need to export LD_LIBRARY_PATH again:"
cat <<'EOF'
export LD_LIBRARY_PATH="$(python - <<'PY'
import site, glob, os
paths=[]
for sp in site.getsitepackages():
    paths.extend(glob.glob(os.path.join(sp, "nvidia", "*", "lib")))
print(":".join(dict.fromkeys(paths)))
PY
):${LD_LIBRARY_PATH:-}"
EOF